{
  "name": "create-vib",
  "version": "0.0.1",
  "description": "Vib — AI SaaS project scaffold",
  "type": "module",
  "bin": {
    "vib": "./dist/bin/vib.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
